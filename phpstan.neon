includes:
    - vendor/phpstan/phpstan-doctrine/extension.neon
    - vendor/phpstan/phpstan-symfony/extension.neon

parameters:
    level: 6
    paths:
        - src/Entity
        - src/Service
        - src/Repository
    excludePaths:
        - src/Entity/.gitignore
        - src/Repository/.gitignore
    doctrine:
        objectManagerLoader: null
    treatPhpDocTypesAsCertain: false
