[2026-04-14T12:42:50.540969+00:00] doctrine.DEBUG: Executing query: INSERT INTO user_quest_progress (user_id, quest_id, progress, status, updated_at)             SELECT                 u.id,                 q.id,                 CASE                     WHEN q.goal = 1 THEN 1                     ELSE LEAST(q.goal, ((u.id * q.id) % q.goal) + IF(q.goal > 2, 1, 0))                 END AS progress_value,                 CASE                     WHEN (                         CASE                             WHEN q.goal = 1 THEN 1                             ELSE LEAST(q.goal, ((u.id * q.id) % q.goal) + IF(q.goal > 2, 1, 0))                         END                     ) >= q.goal THEN 'completed'                     ELSE 'active'                 END AS progress_status,                 NOW()             FROM users u             CROSS JOIN quests q {"sql":"INSERT INTO user_quest_progress (user_id, quest_id, progress, status, updated_at)\r\n            SELECT\r\n                u.id,\r\n                q.id,\r\n                CASE\r\n                    WHEN q.goal = 1 THEN 1\r\n                    ELSE LEAST(q.goal, ((u.id * q.id) % q.goal) + IF(q.goal > 2, 1, 0))\r\n                END AS progress_value,\r\n                CASE\r\n                    WHEN (\r\n                        CASE\r\n                            WHEN q.goal = 1 THEN 1\r\n                            ELSE LEAST(q.goal, ((u.id * q.id) % q.goal) + IF(q.goal > 2, 1, 0))\r\n                        END\r\n                    ) >= q.goal THEN 'completed'\r\n                    ELSE 'active'\r\n                END AS progress_status,\r\n                NOW()\r\n            FROM users u\r\n            CROSS JOIN quests q"} []
