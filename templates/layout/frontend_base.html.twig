<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}TravelXP{% endblock %}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
        {% block stylesheets %}{% endblock %}
    </head>
    <body class="app-body">
        <nav class="navbar app-navbar sticky-top shadow-sm">
            <div class="container px-3 px-md-4">
                <a class="navbar-brand fw-bold" href="{{ path('app_home') }}"><i class="bi bi-airplane-engines-fill me-2"></i>TravelXP</a>
                <div class="d-flex flex-wrap gap-2 ms-auto">
                    <a class="nav-link {% if app.request.attributes.get('_route') starts with 'property_' %}active{% endif %}" href="{{ path('property_index') }}"><i class="bi bi-building me-1"></i>Properties</a>
                    <a class="nav-link {% if app.request.attributes.get('_route') starts with 'offer_' %}active{% endif %}" href="{{ path('offer_index') }}"><i class="bi bi-ticket-perforated me-1"></i>Offers</a>
                    <a class="nav-link {% if app.request.attributes.get('_route') starts with 'booking_' %}active{% endif %}" href="{{ path('booking_index') }}"><i class="bi bi-calendar-check me-1"></i>Bookings</a>
                    <a class="nav-link {% if app.request.attributes.get('_route') starts with 'service_' %}active{% endif %}" href="{{ path('service_index') }}"><i class="bi bi-stars me-1"></i>Services</a>
                    <a class="nav-link" href="{{ path('admin_portal') }}"><i class="bi bi-shield-lock me-1"></i>Admin side</a>
                </div>
            </div>
        </nav>

        <main class="container px-3 px-md-4 py-4">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }} alert-dismissible fade show shadow-sm rounded-4" role="alert">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            {% block frontend_body %}{% endblock %}
        </main>

        <footer class="app-footer py-3 mt-4">
            <div class="container px-3 px-md-4 d-flex justify-content-between flex-wrap gap-2 small text-muted">
                <span><i class="bi bi-compass me-1"></i>TravelXP Front Office</span>
                <span>{{ 'now'|date('Y') }} TravelXP</span>
            </div>
        </footer>
    </body>
</html>
