{% extends (isAdmin|default(false)) ? 'layout/admin_base.html.twig' : 'layout/frontend_base.html.twig' %}

{% block title %}{{ offer.title }} | Offer{% endblock %}

{% block frontend_body %}
    {% set indexRoute = (isAdmin|default(false)) ? 'admin_offer_index' : 'offer_index' %}
    {% set editRoute = (isAdmin|default(false)) ? 'admin_offer_edit' : 'offer_edit' %}
    {% set deleteRoute = (isAdmin|default(false)) ? 'admin_offer_delete' : 'offer_delete' %}
    {% set propertyShowRoute = (isAdmin|default(false)) ? 'admin_property_show' : 'property_show' %}

    <section class="hero-banner mb-4">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-3">
            <div>
                <h1 class="h2 mb-2">{{ offer.title }}</h1>
                <p class="mb-0"><i class="bi bi-building"></i> {{ offer.property ? offer.property.title : '-' }}</p>
            </div>
            <div class="d-flex gap-2">
                {% if offer.property %}
                    <a class="btn btn-info rounded-pill" href="{{ path(propertyShowRoute, {'id': offer.property.id}) }}"><i class="bi bi-house me-1"></i>View property</a>
                {% endif %}
                <a class="btn btn-light rounded-pill" href="{{ path(editRoute, {'id': offer.id}) }}"><i class="bi bi-pencil me-1"></i>Edit</a>
                <form method="post" action="{{ path(deleteRoute, {'id': offer.id}) }}" novalidate="novalidate">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_offer_' ~ offer.id) }}">
                    <button class="btn btn-outline-danger rounded-pill" type="submit">Delete</button>
                </form>
                <a class="btn btn-outline-light rounded-pill" href="{{ path(indexRoute) }}">Back to list</a>
            </div>
        </div>
    </section>

    <div class="row g-4">
        <div class="col-12 col-lg-8">
            <div class="surface-card p-4">
                <h2 class="h5 mb-3"><i class="bi bi-tag me-2"></i>Offer details</h2>
                <div style="line-height: 1.8; color: #333; margin-bottom: 1.5rem;">
                    {{ offer.description ?: '<p class="text-muted fst-italic">No description available.</p>' }}
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge text-bg-warning rounded-pill fs-6">{{ offer.discountPercentage }}% discount</span>
                    {% if offer.isActive %}
                        <span class="badge text-bg-success rounded-pill fs-6">Active</span>
                    {% else %}
                        <span class="badge text-bg-secondary rounded-pill fs-6">Inactive</span>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-4">
            <div class="surface-card p-4">
                <h2 class="h5 mb-3">Timeline</h2>
                <ul class="list-unstyled mb-0 small">
                    <li class="mb-2"><strong>Start date:</strong> {{ offer.startDate ? offer.startDate|date('Y-m-d') : '-' }}</li>
                    <li class="mb-2"><strong>End date:</strong> {{ offer.endDate ? offer.endDate|date('Y-m-d') : '-' }}</li>
                    <li class="mb-2"><strong>Created:</strong> {{ offer.createdAt ? offer.createdAt|date('Y-m-d H:i') : '-' }}</li>
                    <li><strong>Property:</strong> <a href="{{ offer.property ? path(propertyShowRoute, {'id': offer.property.id}) : '#' }}">{{ offer.property ? offer.property.title : '-' }}</a></li>
                </ul>
            </div>
        </div>
    </div>
{% endblock %}

{% block admin_body %}
    {{ block('frontend_body') }}
{% endblock %}
