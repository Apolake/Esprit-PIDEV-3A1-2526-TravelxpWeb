{% set indexRoute = (isAdmin|default(false)) ? 'admin_offer_index' : 'offer_index' %}

{{ form_start(form, {'attr': {'class': 'surface-card p-3 p-md-4', 'novalidate': 'novalidate'}}) }}
    <div class="row g-3">
        <div class="col-12 col-md-6">
            {{ form_label(form.property) }}
            {{ form_widget(form.property, {'attr': {'class': 'form-select'}}) }}
            <div class="field-errors">{{ form_errors(form.property) }}</div>
        </div>
        <div class="col-12 col-md-6">
            {{ form_label(form.title) }}
            {{ form_widget(form.title, {'attr': {'class': 'form-control'}}) }}
            <div class="field-errors">{{ form_errors(form.title) }}</div>
        </div>
        <div class="col-12 col-md-6">
            {{ form_label(form.discountPercentage) }}
            {{ form_widget(form.discountPercentage, {'attr': {'class': 'form-control'}}) }}
            <div class="field-errors">{{ form_errors(form.discountPercentage) }}</div>
        </div>
        <div class="col-12 col-md-3">
            {{ form_label(form.startDate) }}
            {{ form_widget(form.startDate, {'attr': {'class': 'form-control'}}) }}
            <div class="field-errors">{{ form_errors(form.startDate) }}</div>
        </div>
        <div class="col-12 col-md-3">
            {{ form_label(form.endDate) }}
            {{ form_widget(form.endDate, {'attr': {'class': 'form-control'}}) }}
            <div class="field-errors">{{ form_errors(form.endDate) }}</div>
        </div>
        <div class="col-12">
            {{ form_label(form.description) }}
            {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4}}) }}
            <div class="field-errors">{{ form_errors(form.description) }}</div>
        </div>
        <div class="col-12">
            <div class="form-check mt-2">
                {{ form_widget(form.isActive, {'attr': {'class': 'form-check-input'}}) }}
                {{ form_label(form.isActive, null, {'label_attr': {'class': 'form-check-label'}}) }}
            </div>
            <div class="field-errors">{{ form_errors(form.isActive) }}</div>
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <button class="btn btn-primary rounded-pill px-4"><i class="bi bi-check2-circle me-1"></i>{{ button_label|default('Save') }}</button>
        <a href="{{ path(indexRoute) }}" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
    </div>
{{ form_end(form) }}
