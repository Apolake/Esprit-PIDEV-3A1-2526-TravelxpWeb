{% set indexRoute = (isAdmin|default(false)) ? 'admin_offer_index' : 'offer_index' %}

<form method="get" class="surface-card p-3 p-md-4 mb-4" novalidate="novalidate">
    <div class="row g-3 align-items-end">
        <div class="col-12 col-lg-3">
            <label class="form-label" for="q">Search</label>
            <input id="q" type="text" name="q" value="{{ filters.q }}" class="form-control" placeholder="Offer title or property">
        </div>
        <div class="col-6 col-lg-2">
            <label class="form-label" for="propertyId">Property</label>
            <select id="propertyId" name="propertyId" class="form-select">
                <option value="">All</option>
                {% for property in properties %}
                    <option value="{{ property.id }}" {% if filters.propertyId == property.id %}selected{% endif %}>{{ property.title }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="col-6 col-lg-2">
            <label class="form-label" for="active">State</label>
            <select id="active" name="active" class="form-select">
                <option value="">All</option>
                <option value="1" {% if filters.active == '1' %}selected{% endif %}>Active</option>
                <option value="0" {% if filters.active == '0' %}selected{% endif %}>Inactive</option>
            </select>
        </div>
        <div class="col-6 col-lg-2">
            <label class="form-label" for="minDiscount">Min discount</label>
            <input id="minDiscount" type="text" inputmode="decimal" name="minDiscount" value="{{ filters.minDiscount }}" class="form-control">
        </div>
        <div class="col-6 col-lg-2">
            <label class="form-label" for="maxDiscount">Max discount</label>
            <input id="maxDiscount" type="text" inputmode="decimal" name="maxDiscount" value="{{ filters.maxDiscount }}" class="form-control">
        </div>
        <div class="col-6 col-lg-1">
            <label class="form-label" for="validNow">Valid now</label>
            <select id="validNow" name="validNow" class="form-select">
                <option value="">Any</option>
                <option value="1" {% if filters.validNow == '1' %}selected{% endif %}>Yes</option>
            </select>
        </div>
        <div class="col-6 col-lg-2">
            <label class="form-label" for="sort">Sort</label>
            <select id="sort" name="sort" class="form-select">
                <option value="highest_discount" {% if filters.sort == 'highest_discount' %}selected{% endif %}>Highest discount</option>
                <option value="lowest_discount" {% if filters.sort == 'lowest_discount' %}selected{% endif %}>Lowest discount</option>
                <option value="newest" {% if filters.sort == 'newest' %}selected{% endif %}>Newest</option>
                <option value="ending_soon" {% if filters.sort == 'ending_soon' %}selected{% endif %}>Ending soon</option>
            </select>
        </div>
        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-primary rounded-pill px-4"><i class="bi bi-funnel-fill me-1"></i>Apply</button>
            <a class="btn btn-outline-secondary rounded-pill px-4" href="{{ path(indexRoute) }}">Reset</a>
        </div>
    </div>
</form>
