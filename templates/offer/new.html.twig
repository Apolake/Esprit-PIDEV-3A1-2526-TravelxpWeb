{% extends (isAdmin|default(false)) ? 'layout/admin_base.html.twig' : 'layout/frontend_base.html.twig' %}

{% block title %}New Offer | TravelXP{% endblock %}

{% block frontend_body %}
    <section class="hero-banner mb-4">
        <h1 class="h2 mb-2">Create Offer</h1>
        <p class="mb-0">Launch a promotional campaign for a property.</p>
    </section>

    {% include 'offer/_form.html.twig' with {'form': form, 'button_label': 'Create offer'} %}
{% endblock %}

{% block admin_body %}
    {{ block('frontend_body') }}
{% endblock %}
