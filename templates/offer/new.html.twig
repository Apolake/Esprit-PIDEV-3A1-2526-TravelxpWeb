{% extends 'base.html.twig' %}

{% block title %}{{ isAdmin ? 'Admin Menu - New Offer' : 'New Offer' }}{% endblock %}

{% block body %}
    {% set routePrefix = isAdmin ? 'admin_offer_' : 'offer_' %}
    <section class="glass-card">
        <p class="eyebrow">{{ isAdmin ? 'Admin Menu' : 'Front Office' }}</p>
        <h1>Create offer</h1>
        <p class="muted">Configure discount range and validity dates.</p>

        {{ include('offer/_form.html.twig', {button_label: 'Create offer'}) }}

        <a class="btn" href="{{ path(routePrefix ~ 'index') }}">Back to list</a>
    </section>
{% endblock %}
