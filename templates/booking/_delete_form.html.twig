<form method="post" action="{{ path(routePrefix ~ 'delete', {'id': booking.id}) }}" class="inline-form" onsubmit="return confirm('Delete this booking?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete_booking_' ~ booking.id) }}">
    <button class="btn btn-sm btn-danger">Delete</button>
</form>
