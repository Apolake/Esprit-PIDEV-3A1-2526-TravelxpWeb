{% extends 'base.html.twig' %}

{% block title %}{{ isAdmin ? 'Admin Menu - New Booking' : 'New Booking' }}{% endblock %}

{% block body %}
    {% set routePrefix = isAdmin ? 'admin_booking_' : 'booking_' %}
    <section class="glass-card">
        <p class="eyebrow">{{ isAdmin ? 'Admin Menu' : 'Front Office' }}</p>
        <h1>Create booking</h1>
        <p class="muted">Book a property with optional service add-ons.</p>

        {{ include('booking/_form.html.twig', {button_label: 'Create booking'}) }}

        <a class="btn" href="{{ path(routePrefix ~ 'index') }}">Back to list</a>
    </section>
{% endblock %}
