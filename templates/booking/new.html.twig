{% extends 'base.html.twig' %}

{% block title %}{{ isAdmin ? 'Admin Menu - New Booking' : 'New Booking' }}{% endblock %}

{% block body %}
    {% set routePrefix = isAdmin ? 'admin_booking_' : 'booking_' %}
    <section class="glass-card">
        <p class="eyebrow">{{ isAdmin ? 'Admin Menu' : 'Front Office' }}</p>
        <h1>{{ isAdmin ? 'Create booking' : 'Reserve property' }}</h1>
        <p class="muted">{{ isAdmin ? 'Create and manage a booking with full administrative controls.' : 'Choose your dates and optional services to reserve this property.' }}</p>

        {{ include('booking/_form.html.twig', {button_label: isAdmin ? 'Create booking' : 'Reserve now', isAdmin: isAdmin}) }}

        <a class="btn" href="{{ path(routePrefix ~ 'index') }}">Back to list</a>
    </section>
{% endblock %}
