{{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'surface-card p-3 p-md-4'}}) }}
    <div class="row g-3">
        <div class="col-12 col-md-6">
            {{ form_label(form.property) }}
            {{ form_widget(form.property, {'attr': {'class': 'form-select'}}) }}
            <div class="field-errors">{{ form_errors(form.property) }}</div>
        </div>
        <div class="col-12 col-md-6">
            {{ form_label(form.userId) }}
            {{ form_widget(form.userId, {'attr': {'class': 'form-control'}}) }}
            <div class="field-errors">{{ form_errors(form.userId) }}</div>
        </div>
        <div class="col-12 col-md-4">
            {{ form_label(form.bookingDate) }}
            {{ form_widget(form.bookingDate, {'attr': {'class': 'form-control'}}) }}
            <div class="field-errors">{{ form_errors(form.bookingDate) }}</div>
        </div>
        <div class="col-12 col-md-4">
            {{ form_label(form.duration) }}
            {{ form_widget(form.duration, {'attr': {'class': 'form-control'}}) }}
            <div class="field-errors">{{ form_errors(form.duration) }}</div>
        </div>
        <div class="col-12 col-md-4">
            {{ form_label(form.totalPrice) }}
            {{ form_widget(form.totalPrice, {'attr': {'class': 'form-control'}}) }}
            <div class="field-errors">{{ form_errors(form.totalPrice) }}</div>
        </div>
        {% if form.status is defined %}
            <div class="col-12 col-md-6">
                {{ form_label(form.status) }}
                {{ form_widget(form.status, {'attr': {'class': 'form-select'}}) }}
                <div class="field-errors">{{ form_errors(form.status) }}</div>
            </div>
        {% endif %}
        <div class="col-12">
            <label class="form-label">Services</label>
            <div class="surface-card p-3 border rounded-3">
                {{ form_widget(form.services) }}
            </div>
            <div class="field-errors">{{ form_errors(form.services) }}</div>
        </div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button class="btn btn-primary rounded-pill px-4">{{ button_label|default('Save') }}</button>
        <a href="{{ cancel_path }}" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
    </div>
{{ form_end(form) }}
