{% extends 'layout/frontend_base.html.twig' %}

{% block title %}{{ service.providerName }} | Service{% endblock %}

{% block frontend_body %}
    <section class="hero-banner mb-4">
        <div class="d-flex justify-content-between flex-wrap gap-2 align-items-center">
            <div>
                <h1 class="h2 mb-1">{{ service.providerName }}</h1>
                <p class="mb-0">{{ service.serviceType }}</p>
            </div>
            <div class="d-flex gap-2">
                {% if canEdit %}
                    <a href="{{ path('service_edit', {'id': service.id}) }}" class="btn btn-light rounded-pill"><i class="bi bi-pencil me-1"></i>Edit</a>
                {% endif %}
                <a href="{{ path('service_index') }}" class="btn btn-outline-light rounded-pill">Back to services</a>
            </div>
        </div>
    </section>

    <div class="row g-4">
        <div class="col-12 col-lg-8">
            <div class="surface-card p-4">
                <h2 class="h5 mb-3">Service Overview</h2>
                <p class="mb-2"><strong>Description:</strong> {{ service.description ?: 'No description available.' }}</p>
                <p class="mb-2"><strong>Price:</strong> ${{ service.price }}</p>
                <p class="mb-2"><strong>XP Reward:</strong> {{ service.xpReward }}</p>
                <p class="mb-0"><strong>Eco-friendly:</strong> {{ service.ecoFriendly ? 'Yes' : 'No' }}</p>
            </div>
        </div>
        <div class="col-12 col-lg-4">
            <div class="surface-card p-4">
                <h2 class="h5 mb-3">Availability</h2>
                {% include 'service/_status_badge.html.twig' with {'service': service} %}
                <hr>
                <h3 class="h6">Bookings using this service</h3>
                {% if service.bookings is empty %}
                    <p class="text-muted mb-0">No booking currently includes this service.</p>
                {% else %}
                    <ul class="list-group list-group-flush">
                        {% for booking in service.bookings %}
                            <li class="list-group-item px-0">
                                <a href="{{ path('booking_show', {'id': booking.id}) }}">Booking #{{ booking.id }}</a>
                                <small class="text-muted d-block">{{ booking.bookingDate ? booking.bookingDate|date('Y-m-d') : '-' }}</small>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
            {% if canDelete %}
                <form method="post" action="{{ path('service_delete', {'id': service.id}) }}" novalidate="novalidate" class="mt-3">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_service_' ~ service.id) }}">
                    <button class="btn btn-outline-danger w-100" type="submit">Delete service</button>
                </form>
            {% else %}
                <button class="btn btn-secondary w-100 mt-3" type="button" disabled>Linked services cannot be deleted</button>
            {% endif %}
        </div>
    </div>
{% endblock %}
