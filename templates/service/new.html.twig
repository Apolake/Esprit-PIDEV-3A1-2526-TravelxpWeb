{% extends 'base.html.twig' %}

{% block title %}{{ isAdmin ? 'Admin Menu - New Service' : 'New Service' }}{% endblock %}

{% block body %}
    {% set routePrefix = isAdmin ? 'admin_service_' : 'service_' %}
    <section class="glass-card">
        <p class="eyebrow">{{ isAdmin ? 'Admin Menu' : 'Front Office' }}</p>
        <h1>Create service</h1>
        <p class="muted">Add a new add-on service with validated pricing and availability.</p>

        {{ include('service/_form.html.twig', {button_label: 'Create service'}) }}

        <a class="btn" href="{{ path(routePrefix ~ 'index') }}">Back to list</a>
    </section>
{% endblock %}
