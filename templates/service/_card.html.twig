<article class="surface-card h-100 p-3 service-card">
    <div class="d-flex justify-content-between align-items-start mb-2">
        <h3 class="h5 mb-0">{{ service.providerName }}</h3>
        {% include 'service/_status_badge.html.twig' with {'service': service} %}
    </div>
    <p class="text-muted small mb-1"><i class="bi bi-stars me-1"></i>{{ service.serviceType }}</p>
    <p class="small mb-2">{{ service.description ?: 'No description available.' }}</p>
    <div class="d-flex flex-wrap gap-2 mb-3">
        <span class="badge rounded-pill text-bg-light border">${{ service.price }}</span>
        <span class="badge rounded-pill {% if service.ecoFriendly %}text-bg-success{% else %}text-bg-secondary{% endif %}">
            {% if service.ecoFriendly %}Eco-friendly{% else %}Standard{% endif %}
        </span>
        <span class="badge rounded-pill text-bg-info">XP {{ service.xpReward }}</span>
    </div>
    <div class="d-flex gap-2 mt-auto">
        <a class="btn btn-sm btn-outline-primary" href="{{ path(showRoute, {'id': service.id}) }}"><i class="bi bi-eye"></i></a>
        {% if editRoute is defined %}
            <a class="btn btn-sm btn-outline-warning" href="{{ path(editRoute, {'id': service.id}) }}"><i class="bi bi-pencil"></i></a>
        {% endif %}
        {% if deleteRoute is defined and deleteRoute %}
            <form method="post" action="{{ path(deleteRoute, {'id': service.id}) }}" novalidate="novalidate">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_service_' ~ service.id) }}">
                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
            </form>
        {% endif %}
    </div>
</article>
