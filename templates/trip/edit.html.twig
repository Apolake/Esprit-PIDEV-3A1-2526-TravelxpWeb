{% extends 'base.html.twig' %}

{% block title %}Edit Trip | TravelXP{% endblock %}

{% block body %}
    <header class="app-header">
        <h1>Edit Trip #{{ trip.id }}</h1>
        <p>Update fields and save your changes.</p>
    </header>

    <section class="card">
        <div class="card-body">
            {{ include('trip/_form.html.twig', {'button_label': 'Update Trip'}) }}
            <div class="actions" style="margin-top: 12px;">
                <a class="btn btn-secondary" href="{{ path('app_trip_index') }}">Back to list</a>
                <a class="btn btn-secondary" href="{{ path('app_trip_show', {'id': trip.id}) }}">View details</a>
                {{ include('trip/_delete_form.html.twig') }}
            </div>
        </div>
    </section>
{% endblock %}
