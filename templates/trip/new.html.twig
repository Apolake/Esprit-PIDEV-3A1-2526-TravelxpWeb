{% extends 'base.html.twig' %}

{% block title %}Admin Menu - New Trip{% endblock %}

{% block body %}
    {{ include('admin/_operations.html.twig', {active: 'trips'}) }}

    <section class="glass-card panel-head">
        <div>
            <p class="eyebrow">Admin Menu</p>
            <h1>Create trip</h1>
            <p class="muted">Add a new trip users can join from Front Office.</p>
        </div>
        <div class="actions">
            <a class="btn" href="{{ path('admin_trip_index') }}"><i class="fa-solid fa-arrow-left btn-icon" aria-hidden="true"></i>Back to list</a>
        </div>
    </section>

    <section class="glass-card">
        <p class="help-text"><i class="fa-solid fa-circle-info btn-icon" aria-hidden="true"></i>Set total capacity to control seats and waiting-list behavior.</p>
        {{ include('trip/_form.html.twig', {button_label: 'Create trip'}) }}
    </section>
{% endblock %}
