{% extends 'base.html.twig' %}

{% block title %}Create Trip | TravelXP{% endblock %}

{% block body %}
    <header class="app-header">
        <h1>Create New Trip</h1>
        <p>Fill the form below to add a trip to your dashboard.</p>
    </header>

    <section class="card">
        <div class="card-body">
            {{ include('trip/_form.html.twig', {'button_label': 'Save Trip'}) }}
            <div class="actions" style="margin-top: 12px;">
                <a class="btn btn-secondary" href="{{ path('app_trip_index') }}">Back to list</a>
            </div>
        </div>
    </section>
{% endblock %}
