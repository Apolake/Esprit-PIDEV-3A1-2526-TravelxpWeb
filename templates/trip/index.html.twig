{% extends 'base.html.twig' %}

{% block title %}{{ isAdmin ? 'Admin - Trips' : (tripAreaSection == 'my' ? 'My Trips' : 'Browse Trips') }}{% endblock %}

{% block body %}
    {% set tripPlaceholder = asset('images/placeholders/trip.svg') %}
    {% if isAdmin %}
        {{ include('admin/_operations.html.twig', {active: 'trips'}) }}

        <section class="glass-card panel-head">
            <div>
                <p class="eyebrow">Admin Menu</p>
                <h1>Trips Management</h1>
                <p class="muted">Full CRUD over trips, routes, dates, budgets, and participants.</p>
            </div>
            <div class="actions">
                <a class="btn btn-sm" href="{{ path('admin_dashboard') }}"><i class="fa-solid fa-chart-line btn-icon" aria-hidden="true"></i>Dashboard</a>
                <a class="btn btn-primary" href="{{ path('admin_trip_new') }}"><i class="fa-solid fa-plus btn-icon" aria-hidden="true"></i>Create Trip</a>
            </div>
        </section>

        <section class="admin-stats-grid">
            <article class="glass-card metric-card">
                <p class="eyebrow">Trips</p>
                <h3><i class="fa-solid fa-route"></i> {{ adminStats.totalTrips }}</h3>
                <p class="muted">Total trips</p>
            </article>
            <article class="glass-card metric-card">
                <p class="eyebrow">Participation</p>
                <h3><i class="fa-solid fa-user-check"></i> {{ adminStats.joinedTrips }}</h3>
                <p class="muted">Joined trips</p>
            </article>
            <article class="glass-card metric-card">
                <p class="eyebrow">Timeline</p>
                <h3><i class="fa-regular fa-calendar"></i> {{ adminStats.upcomingTrips }}</h3>
                <p class="muted">Upcoming trips</p>
            </article>
            <article class="glass-card metric-card">
                <p class="eyebrow">Status</p>
                <h3><i class="fa-solid fa-circle-check"></i> {{ adminStats.completedTrips }}</h3>
                <p class="muted">Completed trips</p>
            </article>
        </section>

        <section class="glass-card">
            <form class="filters-grid" method="get" action="{{ path('admin_trip_index') }}">
                <div>
                    <label for="trip-q">Search</label>
                    <input id="trip-q" type="search" name="q" value="{{ filters.q }}" placeholder="trip, origin, destination">
                </div>
                <div>
                    <label for="trip-status">Status</label>
                    <select id="trip-status" name="status">
                        <option value="">All statuses</option>
                        {% for st in ['PLANNED','ONGOING','COMPLETED','DONE','CANCELLED'] %}
                            <option value="{{ st }}" {% if filters.status == st %}selected{% endif %}>{{ st|capitalize }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label for="trip-destination">Destination</label>
                    <select id="trip-destination" name="destination">
                        <option value="">All destinations</option>
                        {% for destination in destinations %}
                            <option value="{{ destination }}" {% if filters.destination == destination %}selected{% endif %}>{{ destination }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label for="trip-sort">Sort</label>
                    <select id="trip-sort" name="sort">
                        <option value="newest" {% if filters.sort == 'newest' %}selected{% endif %}>Newest first</option>
                        <option value="oldest" {% if filters.sort == 'oldest' %}selected{% endif %}>Oldest first</option>
                        <option value="name_asc" {% if filters.sort == 'name_asc' %}selected{% endif %}>Name A-Z</option>
                        <option value="name_desc" {% if filters.sort == 'name_desc' %}selected{% endif %}>Name Z-A</option>
                        <option value="date_asc" {% if filters.sort == 'date_asc' %}selected{% endif %}>Start date asc</option>
                        <option value="date_desc" {% if filters.sort == 'date_desc' %}selected{% endif %}>Start date desc</option>
                        <option value="budget_asc" {% if filters.sort == 'budget_asc' %}selected{% endif %}>Budget asc</option>
                        <option value="budget_desc" {% if filters.sort == 'budget_desc' %}selected{% endif %}>Budget desc</option>
                    </select>
                </div>
                <div class="row-actions">
                    <button class="btn btn-sm btn-primary" type="submit"><i class="fa-solid fa-magnifying-glass btn-icon" aria-hidden="true"></i>Apply</button>
                    <a class="btn btn-sm" href="{{ path('admin_trip_index') }}"><i class="fa-solid fa-rotate-left btn-icon" aria-hidden="true"></i>Reset</a>
                </div>
            </form>
        </section>

        <section class="glass-card">
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Route</th>
                            <th>Date range</th>
                            <th>Status</th>
                            <th>Budget</th>
                            <th>Participants</th>
                            <th>Seats</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for trip in trips %}
                            <tr>
                                <td>{{ trip.tripName }}</td>
                                <td>{{ trip.origin ?: '-' }} → {{ trip.destination ?: '-' }}</td>
                                <td>{{ trip.startDate ? trip.startDate|date('Y-m-d') : '-' }} → {{ trip.endDate ? trip.endDate|date('Y-m-d') : '-' }}</td>
                                <td><span class="pill status-{{ trip.status|lower }}">{{ trip.status|capitalize }}</span></td>
                                <td>{{ trip.currency }} {{ (trip.budgetAmount ?? 0)|number_format(2, '.', ',') }}</td>
                                <td>{{ trip.participants|length }}</td>
                                <td><span class="pill">{{ trip.availableSeats }}/{{ trip.totalCapacity }}</span></td>
                                <td class="row-actions">
                                    <a class="btn btn-sm" href="{{ path('admin_trip_show', {'id': trip.id}) }}"><i class="fa-regular fa-eye btn-icon" aria-hidden="true"></i>View</a>
                                    <a class="btn btn-sm" href="{{ path('admin_trip_edit', {'id': trip.id}) }}"><i class="fa-regular fa-pen-to-square btn-icon" aria-hidden="true"></i>Edit</a>
                                    {{ include('trip/_delete_form.html.twig', {trip: trip}) }}
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="8" class="empty-state">No trips found.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>

        <section class="glass-card">
            {{ include('components/_pagination.html.twig', {pagination: pagination, routeName: 'admin_trip_index'}) }}
        </section>
    {% else %}
        <div class="trip-area-layout">
            {{ include('trip/_user_sidebar.html.twig', {section: tripAreaSection}) }}

            <div class="trip-area-main" data-controller="trip-card-ai-drawer">
                <section class="glass-card panel-head">
                    <div>
                        <p class="eyebrow">Trips Workspace</p>
                        <h1>{{ tripAreaSection == 'my' ? 'My Trips' : 'Available Trips' }}</h1>
                        <p class="muted">
                            {{ tripAreaSection == 'my'
                                ? 'Review only the trips you joined and manage participation quickly.'
                                : 'Browse trips, inspect details, and join what fits your plan.' }}
                        </p>
                    </div>
                    <div class="view-toggle">
                        {% set cardsQuery = app.request.query.all|merge({'view': 'cards'}) %}
                        {% set tableQuery = app.request.query.all|merge({'view': 'table'}) %}
                        <a class="btn btn-sm {{ view == 'cards' ? 'btn-primary' : '' }}" href="{{ path(routeName, cardsQuery) }}">Cards</a>
                        <a class="btn btn-sm {{ view == 'table' ? 'btn-primary' : '' }}" href="{{ path(routeName, tableQuery) }}">List</a>
                    </div>
                </section>

                <section class="glass-card">
                    <form class="filters-grid" method="get" action="{{ path(routeName) }}">
                        <input type="hidden" name="view" value="{{ view }}">
                        {% if tripAreaSection == 'my' %}
                            <input type="hidden" name="myTrips" value="1">
                        {% endif %}
                        <div>
                            <label for="trip-q">Search</label>
                            <input id="trip-q" type="search" name="q" value="{{ filters.q }}" placeholder="trip, origin, destination">
                        </div>
                        <div>
                            <label for="trip-status">Status</label>
                            <select id="trip-status" name="status">
                                <option value="">All statuses</option>
                                {% for st in ['PLANNED','ONGOING','COMPLETED','DONE','CANCELLED'] %}
                                    <option value="{{ st }}" {% if filters.status == st %}selected{% endif %}>{{ st|capitalize }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div>
                            <label for="trip-destination">Destination</label>
                            <select id="trip-destination" name="destination">
                                <option value="">All destinations</option>
                                {% for destination in destinations %}
                                    <option value="{{ destination }}" {% if filters.destination == destination %}selected{% endif %}>{{ destination }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div>
                            <label for="trip-sort">Sort</label>
                            <select id="trip-sort" name="sort">
                                <option value="newest" {% if filters.sort == 'newest' %}selected{% endif %}>Newest first</option>
                                <option value="oldest" {% if filters.sort == 'oldest' %}selected{% endif %}>Oldest first</option>
                                <option value="name_asc" {% if filters.sort == 'name_asc' %}selected{% endif %}>Name A-Z</option>
                                <option value="name_desc" {% if filters.sort == 'name_desc' %}selected{% endif %}>Name Z-A</option>
                                <option value="date_asc" {% if filters.sort == 'date_asc' %}selected{% endif %}>Start date asc</option>
                                <option value="date_desc" {% if filters.sort == 'date_desc' %}selected{% endif %}>Start date desc</option>
                                <option value="budget_asc" {% if filters.sort == 'budget_asc' %}selected{% endif %}>Budget asc</option>
                                <option value="budget_desc" {% if filters.sort == 'budget_desc' %}selected{% endif %}>Budget desc</option>
                            </select>
                        </div>
                        <div class="row-actions">
                            <button class="btn btn-sm btn-primary" type="submit"><i class="fa-solid fa-magnifying-glass btn-icon" aria-hidden="true"></i>Apply</button>
                            <a class="btn btn-sm" href="{{ path(routeName, {'view': view}) }}"><i class="fa-solid fa-rotate-left btn-icon" aria-hidden="true"></i>Reset</a>
                        </div>
                    </form>
                </section>

                {% if view == 'cards' %}
                    <section class="trip-card-grid">
                        {% for trip in trips %}
                            {% set joined = trip.id in joinedTripIds %}
                            {% set waiting = trip.id in waitingTripIds %}
                            {% set isFull = trip.availableSeats <= 0 %}
                            {% set rawCover = trip.coverImageUrl ?: '' %}
                            {% set cover = rawCover ? (rawCover starts with 'http' ? rawCover : asset(rawCover starts with '/' ? rawCover|slice(1) : rawCover)) : tripPlaceholder %}
                            <article class="glass-card trip-card-item">
                                <img class="trip-card-image" src="{{ media_thumb(cover, 'trip_card_thumb') }}" alt="{{ trip.tripName }} cover" onerror="this.onerror=null;this.src='{{ tripPlaceholder }}';">
                                <div class="trip-card-body">
                                    <div class="trip-card-head">
                                        <h3>{{ trip.tripName }}</h3>
                                        <span class="pill">{{ trip.status|capitalize }}</span>
                                    </div>
                                    <p class="muted">{{ trip.origin ?: '-' }} → {{ trip.destination ?: '-' }}</p>
                                    <p class="muted">{{ trip.startDate ? trip.startDate|date('M d, Y') : '-' }} - {{ trip.endDate ? trip.endDate|date('M d, Y') : '-' }}</p>
                                    <div class="trip-card-meta">
                                        <span><i class="fa-solid fa-wallet btn-icon" aria-hidden="true"></i>{{ trip.currency }} {{ (trip.budgetAmount ?? 0)|number_format(2, '.', ',') }}</span>
                                        <span><i class="fa-solid fa-users btn-icon" aria-hidden="true"></i>{{ trip.participants|length }} participants</span>
                                        <span><i class="fa-solid fa-chair btn-icon" aria-hidden="true"></i>{{ trip.availableSeats }}/{{ trip.totalCapacity }} seats</span>
                                    </div>
                                    <div class="row-actions">
                                        {% if joined %}
                                            <span class="pill state-joined"><i class="fa-solid fa-circle-check btn-icon" aria-hidden="true"></i>Joined</span>
                                        {% elseif waiting %}
                                            <span class="pill state-waiting"><i class="fa-regular fa-hourglass-half btn-icon" aria-hidden="true"></i>Waiting</span>
                                        {% elseif isFull %}
                                            <span class="pill state-full"><i class="fa-solid fa-circle-exclamation btn-icon" aria-hidden="true"></i>Full</span>
                                        {% else %}
                                            <span class="pill state-available"><i class="fa-solid fa-circle-play btn-icon" aria-hidden="true"></i>Available</span>
                                        {% endif %}
                                    </div>
                                    {% if isFull and not joined and not waiting %}
                                        <p class="help-text"><i class="fa-regular fa-clock"></i>Trip is full. Join action will add you to waiting list.</p>
                                    {% elseif waiting %}
                                        <p class="help-text"><i class="fa-solid fa-list-check"></i>You are currently on this trip waiting list.</p>
                                    {% endif %}
                                    <div class="row-actions">
                                        <a class="btn btn-sm" href="{{ path('trip_show', {'id': trip.id}) }}"><i class="fa-regular fa-eye btn-icon" aria-hidden="true"></i>View Details / Activity</a>
                                        <button
                                            type="button"
                                            class="btn btn-sm"
                                            data-action="click->trip-card-ai-drawer#openFromCard"
                                            data-ai-endpoint="{{ path('trip_ai_assistant', {'id': trip.id}) }}"
                                            data-ai-token="{{ csrf_token('trip_ai_user_' ~ trip.id) }}"
                                            data-trip-id="{{ trip.id }}"
                                            data-trip-name="{{ trip.tripName }}"
                                            data-trip-route="{{ (trip.origin ?: '-') ~ ' -> ' ~ (trip.destination ?: '-') }}"
                                            data-trip-date-range="{{ (trip.startDate ? trip.startDate|date('M d, Y') : '-') ~ ' - ' ~ (trip.endDate ? trip.endDate|date('M d, Y') : '-') }}"
                                            data-trip-status="{{ trip.status|capitalize }}"
                                            data-trip-budget="{{ trip.currency ~ ' ' ~ ((trip.budgetAmount ?? 0)|number_format(2, '.', ',')) }}"
                                        ><i class="fa-solid fa-wand-magic-sparkles btn-icon" aria-hidden="true"></i>AI</button>
                                        {% if joined %}
                                            <form method="post" class="inline-form" action="{{ path('trip_leave', {'id': trip.id}) }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('leave_trip_' ~ trip.id) }}">
                                                <button class="btn btn-sm" type="submit"><i class="fa-solid fa-right-from-bracket btn-icon" aria-hidden="true"></i>Leave Trip</button>
                                            </form>
                                        {% elseif waiting %}
                                            <form method="post" class="inline-form" action="{{ path('trip_leave', {'id': trip.id}) }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('leave_trip_' ~ trip.id) }}">
                                                <button class="btn btn-sm" type="submit"><i class="fa-solid fa-list-check btn-icon" aria-hidden="true"></i>Leave Waiting List</button>
                                            </form>
                                        {% else %}
                                            <form method="post" class="inline-form" action="{{ path('trip_join', {'id': trip.id}) }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('join_trip_' ~ trip.id) }}">
                                                <button class="btn btn-sm btn-primary" type="submit"><i class="fa-solid fa-circle-plus btn-icon" aria-hidden="true"></i>{{ isFull ? 'Join Waiting List' : 'Join Trip' }}</button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </div>
                            </article>
                        {% else %}
                            <article class="glass-card empty-state">{{ tripAreaSection == 'my' ? 'You have not joined any trips yet.' : 'No trips available at the moment.' }}</article>
                        {% endfor %}
                    </section>
                {% else %}
                    <section class="glass-card">
                        <div class="table-wrap">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>Trip</th>
                                        <th>Route</th>
                                        <th>Date range</th>
                                        <th>Status</th>
                                        <th>Budget</th>
                                        <th>Participants</th>
                                        <th>Seats</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for trip in trips %}
                                        {% set joined = trip.id in joinedTripIds %}
                                        {% set waiting = trip.id in waitingTripIds %}
                                        {% set isFull = trip.availableSeats <= 0 %}
                                        <tr>
                                            <td>{{ trip.tripName }}</td>
                                            <td>{{ trip.origin ?: '-' }} → {{ trip.destination ?: '-' }}</td>
                                            <td>{{ trip.startDate ? trip.startDate|date('Y-m-d') : '-' }} → {{ trip.endDate ? trip.endDate|date('Y-m-d') : '-' }}</td>
                                            <td><span class="pill status-{{ trip.status|lower }}">{{ trip.status|capitalize }}</span></td>
                                            <td>{{ trip.currency }} {{ (trip.budgetAmount ?? 0)|number_format(2, '.', ',') }}</td>
                                            <td>{{ trip.participants|length }}</td>
                                            <td><span class="pill">{{ trip.availableSeats }}/{{ trip.totalCapacity }}</span></td>
                                            <td class="row-actions">
                                                <a class="btn btn-sm" href="{{ path('trip_show', {'id': trip.id}) }}"><i class="fa-regular fa-eye btn-icon" aria-hidden="true"></i>View</a>
                                                <button
                                                    type="button"
                                                    class="btn btn-sm"
                                                    data-action="click->trip-card-ai-drawer#openFromCard"
                                                    data-ai-endpoint="{{ path('trip_ai_assistant', {'id': trip.id}) }}"
                                                    data-ai-token="{{ csrf_token('trip_ai_user_' ~ trip.id) }}"
                                                    data-trip-id="{{ trip.id }}"
                                                    data-trip-name="{{ trip.tripName }}"
                                                    data-trip-route="{{ (trip.origin ?: '-') ~ ' -> ' ~ (trip.destination ?: '-') }}"
                                                    data-trip-date-range="{{ (trip.startDate ? trip.startDate|date('M d, Y') : '-') ~ ' - ' ~ (trip.endDate ? trip.endDate|date('M d, Y') : '-') }}"
                                                    data-trip-status="{{ trip.status|capitalize }}"
                                                    data-trip-budget="{{ trip.currency ~ ' ' ~ ((trip.budgetAmount ?? 0)|number_format(2, '.', ',')) }}"
                                                ><i class="fa-solid fa-wand-magic-sparkles btn-icon" aria-hidden="true"></i>AI</button>
                                                {% if joined %}
                                                    <form method="post" class="inline-form" action="{{ path('trip_leave', {'id': trip.id}) }}">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('leave_trip_' ~ trip.id) }}">
                                                        <button class="btn btn-sm" type="submit"><i class="fa-solid fa-right-from-bracket btn-icon" aria-hidden="true"></i>Leave</button>
                                                    </form>
                                                {% elseif waiting %}
                                                    <form method="post" class="inline-form" action="{{ path('trip_leave', {'id': trip.id}) }}">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('leave_trip_' ~ trip.id) }}">
                                                        <button class="btn btn-sm" type="submit"><i class="fa-solid fa-list-check btn-icon" aria-hidden="true"></i>Leave waiting</button>
                                                    </form>
                                                {% else %}
                                                    <form method="post" class="inline-form" action="{{ path('trip_join', {'id': trip.id}) }}">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('join_trip_' ~ trip.id) }}">
                                                        <button class="btn btn-sm btn-primary" type="submit"><i class="fa-solid fa-circle-plus btn-icon" aria-hidden="true"></i>{{ isFull ? 'Waitlist' : 'Join' }}</button>
                                                    </form>
                                                {% endif %}
                                                {% if waiting %}
                                                    <span class="pill state-waiting">Waiting</span>
                                                {% elseif isFull and not joined %}
                                                    <span class="pill state-full">Full</span>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% else %}
                                        <tr><td colspan="8" class="empty-state">No trips found.</td></tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </section>
                {% endif %}

                <aside class="trip-ai-drawer-backdrop" data-trip-card-ai-drawer-target="drawer" data-action="click->trip-card-ai-drawer#closeOnBackdrop" hidden>
                    <section class="trip-ai-drawer glass-card" role="dialog" aria-modal="true" aria-label="Trip AI Assistant panel">
                        <div class="panel-head compact">
                            <div>
                                <p class="eyebrow">Trip AI Assistant</p>
                                <h3 data-trip-card-ai-drawer-target="title">AI for this trip</h3>
                                <p class="muted" data-trip-card-ai-drawer-target="meta"></p>
                            </div>
                            <button class="btn btn-sm" type="button" data-action="trip-card-ai-drawer#close"><i class="fa-solid fa-xmark btn-icon" aria-hidden="true"></i>Close</button>
                        </div>

                        <div class="ai-question-grid">
                            <button type="button" class="btn btn-sm" data-trip-card-ai-drawer-target="questionButton" data-question-key="wear" data-action="trip-card-ai-drawer#askPreset">What should I wear?</button>
                            <button type="button" class="btn btn-sm" data-trip-card-ai-drawer-target="questionButton" data-question-key="risks" data-action="trip-card-ai-drawer#askPreset">Risks & cautions</button>
                            <button type="button" class="btn btn-sm" data-trip-card-ai-drawer-target="questionButton" data-question-key="prepare" data-action="trip-card-ai-drawer#askPreset">What to prepare</button>
                            <button type="button" class="btn btn-sm" data-trip-card-ai-drawer-target="questionButton" data-question-key="best_activities" data-action="trip-card-ai-drawer#askPreset">Best activities</button>
                            <button type="button" class="btn btn-sm" data-trip-card-ai-drawer-target="questionButton" data-question-key="low_budget" data-action="trip-card-ai-drawer#askPreset">Low budget suitability</button>
                            <button type="button" class="btn btn-sm" data-trip-card-ai-drawer-target="questionButton" data-question-key="avoid" data-action="trip-card-ai-drawer#askPreset">What to avoid</button>
                            <button type="button" class="btn btn-sm" data-trip-card-ai-drawer-target="questionButton" data-question-key="highlights" data-action="trip-card-ai-drawer#askPreset">Destination highlights</button>
                        </div>

                        <article class="glass-card ai-output-card">
                            <h4 data-trip-card-ai-drawer-target="outputTitle">Trip Assistant</h4>
                            <p class="ai-output-body" data-trip-card-ai-drawer-target="outputBody">Choose a question to get AI guidance for this selected trip card.</p>
                        </article>
                        <section class="trip-ai-messages" data-trip-card-ai-drawer-target="messages"></section>
                        <form class="trip-ai-chat-form" data-action="submit->trip-card-ai-drawer#sendMessage">
                            <label for="trip-ai-chat-input">Ask about this trip</label>
                            <div class="trip-ai-chat-input-row">
                                <input
                                    id="trip-ai-chat-input"
                                    type="text"
                                    placeholder="Type your trip question..."
                                    data-trip-card-ai-drawer-target="chatInput"
                                >
                                <button type="submit" class="btn btn-primary btn-sm" data-trip-card-ai-drawer-target="sendButton">
                                    <i class="fa-solid fa-paper-plane btn-icon" aria-hidden="true"></i>Send
                                </button>
                            </div>
                        </form>
                    </section>
                </aside>

                {% if tripAreaSection == 'my' and trips is empty %}
                    <section class="glass-card center">
                        <h3>Join More Trips</h3>
                        <p class="muted">You can discover available trips and start joining from the browse section.</p>
                        <a class="btn btn-primary" href="{{ path('trip_browse') }}"><i class="fa-solid fa-compass btn-icon" aria-hidden="true"></i>Browse Trips</a>
                    </section>
                {% endif %}

                <section class="glass-card">
                    {{ include('components/_pagination.html.twig', {pagination: pagination, routeName: routeName}) }}
                </section>
            </div>
        </div>
    {% endif %}
{% endblock %}
