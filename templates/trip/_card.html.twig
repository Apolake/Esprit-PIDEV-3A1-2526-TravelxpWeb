<article class="surface-card h-100 p-3">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h3 class="h5 mb-0">{{ trip.tripName }}</h3>
        {% set state = (trip.status ?? 'PLANNED') %}
        <span class="badge {% if state in ['COMPLETED','DONE'] %}text-bg-success{% elseif state == 'CANCELLED' %}text-bg-danger{% else %}text-bg-primary{% endif %}">
            {{ state }}
        </span>
    </div>
    <p class="small text-muted mb-1"><i class="bi bi-signpost-split me-1"></i>{{ trip.origin ?? '-' }} -> {{ trip.destination ?? '-' }}</p>
    <p class="small text-muted mb-1"><i class="bi bi-calendar3 me-1"></i>{{ trip.startDate ? trip.startDate|date('Y-m-d') : '-' }} -> {{ trip.endDate ? trip.endDate|date('Y-m-d') : '-' }}</p>
    <p class="small text-muted mb-2"><i class="bi bi-cash-stack me-1"></i>{{ trip.currency ?? 'USD' }} {{ trip.budgetAmount ?? 0 }}</p>
    <p class="small mb-3">{{ trip.description ? trip.description|slice(0, 100) ~ (trip.description|length > 100 ? '...' : '') : 'No description.' }}</p>
    <div class="d-flex gap-2 mt-auto">
        <a class="btn btn-sm btn-outline-primary" href="{{ path('app_trip_show', {'id': trip.id}) }}"><i class="bi bi-eye"></i></a>
        <a class="btn btn-sm btn-outline-warning" href="{{ path('app_trip_edit', {'id': trip.id}) }}"><i class="bi bi-pencil"></i></a>
    </div>
</article>
