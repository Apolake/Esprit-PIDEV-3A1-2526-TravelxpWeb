{% extends 'base.html.twig' %}

{% block title %}Payment history{% endblock %}

{% block body %}
    <section class="glass-card panel-head">
        <div>
            <p class="eyebrow">Wallet</p>
            <h1>My payment history</h1>
            <p class="muted">Recharge your wallet and review booking payments made from your balance.</p>
        </div>
        <div class="mini-stat">
            <span>Wallet balance</span>
            <strong>USD {{ walletBalance|number_format(2, '.', ',') }}</strong>
        </div>
    </section>

    <section class="glass-card">
        <h2>Recharge wallet</h2>
        <form method="post" class="stack-form" action="{{ path('app_wallet_top_up') }}" data-turbo="false">
            <input type="hidden" name="_token" value="{{ csrf_token('wallet_top_up') }}">
            <label for="wallet-top-up-amount">Amount</label>
            <input id="wallet-top-up-amount" type="number" name="amount" min="1" step="0.01" value="50.00" required>
            <button type="submit" class="btn btn-primary">Add funds</button>
        </form>
    </section>

    <section class="glass-card">
        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Reference</th>
                        <th>Booking</th>
                        <th>Budget</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    {% for payment in payments %}
                        <tr>
                            <td>{{ payment.stripePaymentIntentId }}</td>
                            <td>
                                {% if payment.booking %}
                                    <a href="{{ path('booking_show', {'id': payment.booking.id}) }}">#{{ payment.booking.id }}</a>
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                            <td>{{ payment.budget ? payment.budget.title : '—' }}</td>
                            <td>{{ payment.currency }} {{ payment.amount|number_format(2, '.', ',') }}</td>
                            <td><span class="pill">{{ payment.status|replace({'_': ' '})|capitalize }}</span></td>
                            <td>{{ payment.createdAt ? payment.createdAt|date('Y-m-d H:i') : '—' }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="empty-state">No payments found yet.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
