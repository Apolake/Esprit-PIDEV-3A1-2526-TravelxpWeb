{% extends 'base.html.twig' %}

{% block title %}{{ isAdmin ? 'Admin Menu - Property' : 'Property Details' }}{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
{% endblock %}

{% block body %}
    {% set routePrefix = isAdmin ? 'admin_property_' : 'property_' %}
    {% set imagePath = property.images ? property.images|replace({'\\': '/'}) : null %}
    {% set imageSrc = imagePath ? (imagePath starts with 'http' ? imagePath : asset(imagePath starts with '/' ? imagePath|slice(1) : imagePath)) : null %}

    <section class="glass-card">
        <p class="eyebrow">{{ isAdmin ? 'Admin Menu' : 'Front Office' }}</p>
        <h1>{{ property.title }}</h1>

        {% if imageSrc %}
            <img src="{{ imageSrc }}" alt="{{ property.title }}" style="width:100%;max-height:320px;object-fit:cover;border-radius:16px;margin-bottom:1rem;">
        {% endif %}

        <dl class="details-grid">
            <dt>Type</dt><dd>{{ property.propertyType }}</dd>
            <dt>Location</dt><dd>{{ property.city }}, {{ property.country }}</dd>
            <dt>Address</dt><dd>{{ property.address ?: '—' }}</dd>
            <dt>Price per night</dt><dd>{{ formattedConvertedPrice }}</dd>
            <dt>Bedrooms</dt><dd>{{ property.bedrooms }}</dd>
            <dt>Max guests</dt><dd>{{ property.maxGuests }}</dd>
            <dt>Status</dt><dd>{{ property.isActive ? 'Active' : 'Inactive' }}</dd>
            <dt>Description</dt><dd>{{ property.description ?: '—' }}</dd>
            <dt>Created</dt><dd>{{ property.createdAt ? property.createdAt|date('Y-m-d H:i') : '—' }}</dd>
            <dt>Updated</dt><dd>{{ property.updatedAt ? property.updatedAt|date('Y-m-d H:i') : '—' }}</dd>
        </dl>

        {% if property.latitude is not null and property.longitude is not null and geoapifyMapTilesApiKey is not empty %}
            <section
                class="map-panel"
                data-controller="route-map"
                data-route-map-lat-value="{{ property.latitude }}"
                data-route-map-lng-value="{{ property.longitude }}"
                data-route-map-route-url-value="{{ path('geoapify_route') }}"
                data-route-map-places-url-value="{{ path('geoapify_places') }}"
                data-route-map-api-key-value="{{ geoapifyMapTilesApiKey }}"
                data-route-map-tiles-url-value="{{ geoapifyMapTilesUrl|default('') }}"
            >
                <h2>Location and nearby places</h2>
                <p class="muted route-map-status" data-route-map-target="status">Click the button to detect your location, draw a route, and load nearby places.</p>
                <div class="route-map-actions">
                    <button
                        type="button"
                        class="btn btn-primary"
                        data-route-map-target="button"
                        data-action="click->route-map#calculateRoute"
                    >
                        Calculate Route &amp; View Nearby Places
                    </button>
                </div>
                <div class="property-map" data-route-map-target="map"></div>
            </section>
        {% else %}
            <section class="map-panel">
                <h2>Location and nearby places</h2>
                <p class="muted">Location coordinates are not available yet. Edit the property address to generate them.</p>
            </section>
        {% endif %}

        {% if not isAdmin %}
            <div
                class="chatbot-container"
                data-controller="chatbot"
                data-chatbot-property-id-value="{{ property.id }}"
                data-chatbot-chat-url-value="{{ path('property_chat', {'id': property.id}) }}"
                data-chatbot-open-value="{{ chatHistory is not empty ? 'true' : 'false' }}"
            >
                <button type="button" class="chat-toggle" data-chatbot-target="toggleButton" data-action="click->chatbot#toggle" aria-expanded="{{ chatHistory is not empty ? 'true' : 'false' }}" aria-label="Open chat">
                    💬
                </button>

                <aside class="chatbox glass-card" data-chatbot-target="box">
                    <div class="chatbox-header">
                        <div>
                            <p class="eyebrow">AI Assistant</p>
                            <h2>Ask about this property</h2>
                        </div>
                        <button type="button" class="chatbox-close" data-action="click->chatbot#toggle" aria-label="Close chat">✕</button>
                    </div>

                    <div class="chatbox-suggestions">
                        <button type="button" class="chat-suggestion" data-action="click->chatbot#useSuggestion" data-suggestion-text="Any discounts?">Any discounts?</button>
                        <button type="button" class="chat-suggestion" data-action="click->chatbot#useSuggestion" data-suggestion-text="Is this good for 4 people?">Is this good for 4 people?</button>
                        <button type="button" class="chat-suggestion" data-action="click->chatbot#useSuggestion" data-suggestion-text="Show best offer">Show best offer</button>
                    </div>

                    <div class="chatbox-messages" data-chatbot-target="messages" aria-live="polite" aria-label="Chat messages">
                        {% if chatHistory is not empty %}
                            {% for entry in chatHistory %}
                                <div class="chatbot-message {{ entry.role == 'assistant' ? 'bot' : 'user' }}" data-role="{{ entry.role }}" data-content="{{ entry.content|e('html_attr') }}" data-timestamp="{{ entry.timestamp|default('')|e('html_attr') }}">
                                    <div class="chatbot-message-text">{{ entry.content }}</div>
                                    <div class="chatbot-message-time">{{ entry.timestamp|default('') }}</div>
                                </div>
                            {% endfor %}
                        {% else %}
                            <div class="chatbot-message bot" data-role="assistant" data-content="Ask me about discounts, guest capacity, or the best offer for this property." data-timestamp="">
                                <div class="chatbot-message-text">Ask me about discounts, guest capacity, or the best offer for this property.</div>
                                <div class="chatbot-message-time"></div>
                            </div>
                        {% endif %}
                    </div>

                    <div class="chatbot-status" data-chatbot-target="status" aria-live="polite"></div>

                    <div class="chatbox-input-row">
                        <input
                            type="text"
                            placeholder="Ask about this property..."
                            autocomplete="off"
                            maxlength="500"
                            data-chatbot-target="input"
                            data-action="keydown.enter->chatbot#sendMessage"
                        >
                        <button type="button" class="btn btn-primary" data-chatbot-target="sendButton" data-action="click->chatbot#sendMessage">Send</button>
                    </div>
                </aside>
            </div>
        {% endif %}

        <div class="row-actions">
            <a class="btn btn-primary" href="{{ path(isAdmin ? 'admin_property_pdf' : 'property_pdf', {'id': property.id}) }}">Download PDF</a>
            <a class="btn" href="{{ path(routePrefix ~ 'index') }}">Back to list</a>
            {% if isAdmin %}
                <a class="btn btn-primary" href="{{ path(routePrefix ~ 'edit', {'id': property.id}) }}">Edit</a>
                {{ include('property/_delete_form.html.twig', {routePrefix: routePrefix, property: property}) }}
            {% else %}
                <a class="btn btn-primary" href="{{ path('booking_new', {'propertyId': property.id}) }}">Rent this property</a>
            {% endif %}
        </div>
    </section>
{% endblock %}
