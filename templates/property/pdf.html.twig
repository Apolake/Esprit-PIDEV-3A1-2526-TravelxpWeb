<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ property.title }} - Property PDF</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            color: #1f2937;
            font-size: 12px;
            line-height: 1.5;
        }
        .header {
            border-bottom: 2px solid #0f172a;
            margin-bottom: 18px;
            padding-bottom: 10px;
        }
        h1, h2 {
            margin: 0 0 10px 0;
            color: #0f172a;
        }
        .meta {
            margin-bottom: 16px;
        }
        .meta p {
            margin: 4px 0;
        }
        .hero-image {
            width: 100%;
            max-height: 260px;
            object-fit: cover;
            border-radius: 10px;
            margin: 14px 0 18px;
        }
        .section {
            margin-top: 18px;
        }
        .offer {
            border: 1px solid #d1d5db;
            border-radius: 8px;
            padding: 10px 12px;
            margin-bottom: 10px;
        }
        .muted {
            color: #6b7280;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>{{ property.title }}</h1>
        <div class="muted">Property details and related offers</div>
    </div>

    {% if imageSrc %}
        <img class="hero-image" src="{{ imageSrc }}" alt="{{ property.title }}">
    {% elseif pdfImageWarning %}
        <p class="muted">{{ pdfImageWarning }}</p>
    {% endif %}

    <div class="meta">
        <p><strong>Type:</strong> {{ property.propertyType ?: '—' }}</p>
        <p><strong>Description:</strong> {{ property.description ?: '—' }}</p>
        <p><strong>Location:</strong> {{ property.address ?: '—' }}, {{ property.city ?: '—' }}, {{ property.country ?: '—' }}</p>
        <p><strong>Price per night:</strong> {{ property.pricePerNight is not null ? property.pricePerNight|number_format(2, '.', ',') ~ ' USD' : '—' }}</p>
        <p><strong>Bedrooms:</strong> {{ property.bedrooms ?: '—' }}</p>
        <p><strong>Max guests:</strong> {{ property.maxGuests ?: '—' }}</p>
        <p><strong>Status:</strong> {{ property.isActive ? 'Active' : 'Inactive' }}</p>
        <p><strong>Coordinates:</strong> {{ property.latitude is not null and property.longitude is not null ? property.latitude ~ ', ' ~ property.longitude : '—' }}</p>
    </div>

    <div class="section">
        <h2>Offers</h2>

        {% if offers|length > 0 %}
            {% for offer in offers %}
                <div class="offer">
                    <p><strong>{{ offer.title ?: 'Untitled offer' }}</strong></p>
                    <p><strong>Discount:</strong> {{ offer.discountPercentage is not null ? offer.discountPercentage|number_format(2, '.', ',') ~ '%' : '—' }}</p>
                    <p><strong>Dates:</strong> {{ offer.startDate ? offer.startDate|date('Y-m-d') : '—' }} → {{ offer.endDate ? offer.endDate|date('Y-m-d') : '—' }}</p>
                    <p><strong>Status:</strong> {{ offer.isActive ? 'Active' : 'Inactive' }}</p>
                    {% if offer.description %}
                        <p><strong>Description:</strong> {{ offer.description }}</p>
                    {% endif %}
                </div>
            {% endfor %}
        {% else %}
            <p class="muted">No offers available.</p>
        {% endif %}
    </div>
</body>
</html>