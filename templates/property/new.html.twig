{% extends 'base.html.twig' %}

{% block title %}{{ isAdmin ? 'Admin Menu - New Property' : 'New Property' }}{% endblock %}

{% block body %}
    {% set routePrefix = isAdmin ? 'admin_property_' : 'property_' %}
    <section class="glass-card">
        <p class="eyebrow">{{ isAdmin ? 'Admin Menu' : 'Front Office' }}</p>
        <h1>Create property</h1>
        <p class="muted">Publish a property listing with full validation.</p>

        {{ include('property/_form.html.twig', {button_label: 'Create property'}) }}

        <a class="btn" href="{{ path(routePrefix ~ 'index') }}">Back to list</a>
    </section>
{% endblock %}
