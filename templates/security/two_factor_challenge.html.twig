{% extends 'base.html.twig' %}

{% block title %}Two-factor verification{% endblock %}

{% block body %}
    <section class="auth-shell">
        <form method="post" class="glass-card auth-card stack-form" novalidate>
            <p class="eyebrow">Security</p>
            <h1>Two-factor verification</h1>
            <p class="muted">Enter the 6-digit code from your authenticator app, or a recovery code.</p>

            <label for="code">Authentication code</label>
            <input id="code" name="code" type="text" inputmode="numeric" autocomplete="one-time-code" required>
            <input type="hidden" name="_token" value="{{ csrf_token('totp_challenge') }}">

            <button class="btn btn-primary btn-block" type="submit">Verify</button>
            <a class="btn btn-block" href="{{ path('app_logout') }}">Logout</a>
        </form>
    </section>
{% endblock %}
