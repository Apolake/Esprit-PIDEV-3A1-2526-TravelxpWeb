{% extends 'base.html.twig' %}

{% block title %}Profile - Two-factor setup{% endblock %}

{% block body %}
    <section class="glass-card panel-head">
        <div>
            <p class="eyebrow">Profile</p>
            <h1>Two-factor authentication</h1>
            <p class="muted">Scan the QR code and verify one code to complete setup.</p>
        </div>
        <a class="btn" href="{{ path('app_profile_show') }}">Back to profile</a>
    </section>

    <section class="glass-card">
        <div class="two-factor-grid">
            <article class="two-factor-qr">
                <h2>Authenticator QR</h2>
                <img src="{{ qrCodeDataUri }}" alt="Authenticator QR code" class="totp-qr">
                <p class="help-text">Manual key: <strong>{{ secret }}</strong></p>
            </article>
            <article class="two-factor-verify">
                <h2>Enable 2FA</h2>
                <form method="post" class="stack-form" novalidate>
                    <input type="hidden" name="_token" value="{{ csrf_token('enable_totp') }}">
                    <input type="hidden" name="action" value="enable">
                    <label for="totp-code">Authenticator code</label>
                    <input id="totp-code" name="code" type="text" inputmode="numeric" autocomplete="one-time-code" required>
                    <button type="submit" class="btn btn-primary">Enable two-factor auth</button>
                </form>

                <form method="post" class="stack-form" style="margin-top: 1rem;" novalidate>
                    <input type="hidden" name="_token" value="{{ csrf_token('regenerate_totp_recovery') }}">
                    <input type="hidden" name="action" value="regenerate_recovery">
                    <button type="submit" class="btn">Regenerate recovery codes</button>
                </form>
            </article>
        </div>
    </section>

    <section class="glass-card">
        <h2>Recovery codes</h2>
        <p class="muted">Save these codes in a safe place. Each code can only be used once.</p>
        <div class="recovery-code-grid">
            {% for code in recoveryCodes %}
                <code>{{ code }}</code>
            {% else %}
                <p class="muted">Recovery codes are hidden. Regenerate to display a new set.</p>
            {% endfor %}
        </div>
    </section>
{% endblock %}
