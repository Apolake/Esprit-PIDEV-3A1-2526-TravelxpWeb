                    <img src="{{ asset('icon.png') }}" alt="TravelXP">
                </span>
                <span>TravelXP</span>
            </a>
            <nav class="topnav">
                <div class="topnav-links">
                    <a class="{{ currentRoute == 'app_home' ? 'active' : '' }}" href="{{ path('app_home') }}">Home</a>
                    {% if app.user %}
                        {% if 'ROLE_ADMIN' in app.user.roles %}
