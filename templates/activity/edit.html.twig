{% extends 'base.html.twig' %}

{% block title %}Edit Activity | TravelXP{% endblock %}

{% block body %}
    <header class="app-header">
        <h1>Edit Activity #{{ activity.id }}</h1>
        <p>Update details and trip link.</p>
    </header>

    <section class="card">
        <div class="card-body">
            {{ include('activity/_form.html.twig', {'button_label': 'Update Activity'}) }}
            <div class="actions" style="margin-top: 12px;">
                <a class="btn btn-secondary" href="{{ path('app_activity_index') }}">Back to list</a>
                <a class="btn btn-secondary" href="{{ path('app_activity_show', {'id': activity.id}) }}">View details</a>
                {{ include('activity/_delete_form.html.twig') }}
            </div>
        </div>
    </section>
{% endblock %}
