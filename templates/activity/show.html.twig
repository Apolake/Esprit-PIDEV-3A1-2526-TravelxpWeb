{% extends 'base.html.twig' %}

{% block title %}{{ isAdmin ? 'Admin - Activity Details' : 'Activity Details' }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
{% endblock %}

{% block body %}
    {% set activityPlaceholder = asset('images/placeholders/activity.svg') %}
    {% set rawImage = activity.imageUrl ?: '' %}
    {% set activityImage = rawImage ? (rawImage starts with 'http' ? rawImage : asset(rawImage starts with '/' ? rawImage|slice(1) : rawImage)) : activityPlaceholder %}
    {% set routePrefix = isAdmin ? 'admin_activity_' : 'activity_' %}

    {% if isAdmin %}
        {{ include('admin/_operations.html.twig', {active: 'activities'}) }}

        <section class="glass-card panel-head">
            <div>
                <p class="eyebrow">Admin Menu</p>
                <h1>{{ activity.title }}</h1>
                <p class="muted">{{ activity.description ?: 'No description provided.' }}</p>
            </div>
            <div class="actions">
                <a class="btn" href="{{ path('admin_activity_index') }}">Back to list</a>
                <a class="btn btn-primary" href="{{ path('admin_activity_edit', {'id': activity.id}) }}">Edit</a>
                {{ include('activity/_delete_form.html.twig', {activity: activity}) }}
            </div>
        </section>

        <section class="glass-card details-layout">
            <img class="trip-hero-image" src="{{ media_thumb(activityImage, 'activity_hero_thumb') }}" alt="{{ activity.title }}" onerror="this.onerror=null;this.src='{{ activityPlaceholder }}';">
            <dl class="details-grid">
                <dt>Type</dt><dd>{{ activity.type ?: '-' }}</dd>
                <dt>Status</dt><dd><span class="pill status-{{ activity.status|lower }}">{{ activity.status|capitalize }}</span></dd>
                <dt>Trip</dt><dd>{{ activity.trip ? activity.trip.tripName : '-' }}</dd>
                <dt>Date</dt><dd>{{ activity.activityDate ? activity.activityDate|date('Y-m-d') : '-' }}</dd>
                <dt>Start time</dt><dd>{{ activity.startTime ? activity.startTime|date('H:i') : '-' }}</dd>
                <dt>End time</dt><dd>{{ activity.endTime ? activity.endTime|date('H:i') : '-' }}</dd>
                <dt>Location</dt><dd>{{ activity.locationName ?: '-' }}</dd>
                <dt>Transport</dt><dd>{{ activity.transportType ?: '-' }}</dd>
                <dt>Cost</dt>
                <dd>
                    {{ activity.currency }} {{ (activity.costAmount ?? 0)|number_format(2, '.', ',') }}
                    {% if showConvertedValues %}
                        <br><span class="muted">{{ selectedCurrency }} {{ activityCostConverted|number_format(2, '.', ',') }}</span>
                    {% endif %}
                </dd>
                <dt>XP earned</dt><dd>{{ activity.xpEarned ?? 0 }}</dd>
                <dt>Participants</dt><dd>{{ activity.participants|length }}</dd>
                <dt>Available seats</dt><dd>{{ activity.availableSeats }} / {{ activity.totalCapacity }}</dd>
                <dt>Image URL</dt><dd>{{ activity.imageUrl ?: '-' }}</dd>
            </dl>
        </section>

        <section class="glass-card panel-head">
            <div>
                <p class="eyebrow">Location Map</p>
                <h2>Activity Location</h2>
                <p class="muted">Pinpointed map for this activity location.</p>
            </div>
            <div class="actions">
                {% if externalMapUrl %}
                    <a class="btn btn-sm" href="{{ externalMapUrl }}" target="_blank" rel="noopener"><i class="fa-solid fa-map-location-dot btn-icon" aria-hidden="true"></i>View on map</a>
                {% endif %}
            </div>
        </section>

        {% if hasActivityMapCoordinates %}
            <section class="trip-map-weather-grid">
                <article class="glass-card" data-controller="trip-map" data-trip-map-center-lat-value="{{ mapCenterLat is not null ? mapCenterLat : '' }}" data-trip-map-center-lng-value="{{ mapCenterLng is not null ? mapCenterLng : '' }}" data-trip-map-activities-value="{{ activityMapItems|json_encode }}" data-trip-map-center-label-value="Activity location" data-trip-map-show-center-marker-value="false">
                    <div class="panel-head">
                        <div>
                            <p class="eyebrow">Activity Map</p>
                            <h3>{{ activity.locationName ?: 'Pinned location' }}</h3>
                        </div>
                    </div>
                    <div class="trip-map-root" data-trip-map-root></div>
                </article>
            </section>
        {% else %}
            <section class="glass-card center">
                <p class="muted">Map data is unavailable for this activity right now. Add/confirm location coordinates to enable map pinning.</p>
            </section>
        {% endif %}
    {% else %}
        <div class="trip-area-layout">
            {{ include('trip/_user_sidebar.html.twig', {section: 'activities'}) }}

            <div class="trip-area-main">
                <section class="glass-card panel-head">
                    <div>
                        <p class="eyebrow">Activity Details</p>
                        <h1>{{ activity.title }}</h1>
                        <p class="muted">{{ activity.description ?: 'No description provided.' }}</p>
                    </div>
                    <div class="actions">
                        <a class="btn" href="{{ path('trip_my_activities') }}">My Activities</a>
                        <form method="get" action="{{ path('activity_show', {'id': activity.id}) }}" class="inline-form">
                            <select name="currency">
                                {% for code, label in supportedCurrencies %}
                                    <option value="{{ code }}" {% if selectedCurrency == code %}selected{% endif %}>{{ label }}</option>
                                {% endfor %}
                            </select>
                            <button class="btn btn-sm" type="submit">Currency</button>
                        </form>
                        {% if app.user %}
                            {% if isJoined %}
                                <form method="post" class="inline-form" action="{{ path('activity_leave', {'id': activity.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('leave_activity_' ~ activity.id) }}">
                                    <button class="btn" type="submit">Leave Activity</button>
                                </form>
                            {% elseif isWaiting %}
                                <form method="post" class="inline-form" action="{{ path('activity_leave', {'id': activity.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('leave_activity_' ~ activity.id) }}">
                                    <button class="btn" type="submit">Leave Waiting List</button>
                                </form>
                                <span class="pill state-waiting">Waiting</span>
                            {% elseif canJoinTrip %}
                                <form method="post" class="inline-form" action="{{ path('activity_join', {'id': activity.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('join_activity_' ~ activity.id) }}">
                                    <button class="btn btn-primary" type="submit">{{ activity.availableSeats <= 0 ? 'Join Waiting List' : 'Join Activity' }}</button>
                                </form>
                                {% if activity.availableSeats <= 0 %}
                                    <span class="pill state-full">Full</span>
                                {% endif %}
                            {% elseif not hasLinkedTrip %}
                                <span class="pill">No linked trip</span>
                            {% else %}
                                <span class="pill">Join the trip first</span>
                            {% endif %}
                        {% endif %}
                    </div>
                </section>

                <section class="glass-card details-layout">
                    <img class="trip-hero-image" src="{{ media_thumb(activityImage, 'activity_hero_thumb') }}" alt="{{ activity.title }}" onerror="this.onerror=null;this.src='{{ activityPlaceholder }}';">
                    <dl class="details-grid">
                        <dt>Trip</dt><dd>{{ activity.trip ? activity.trip.tripName : '-' }}</dd>
                        <dt>Type</dt><dd>{{ activity.type ?: '-' }}</dd>
                        <dt>Status</dt><dd><span class="pill status-{{ activity.status|lower }}">{{ activity.status|capitalize }}</span></dd>
                        <dt>Date</dt><dd>{{ activity.activityDate ? activity.activityDate|date('M d, Y') : '-' }}</dd>
                        <dt>Start</dt><dd>{{ activity.startTime ? activity.startTime|date('H:i') : '-' }}</dd>
                        <dt>End</dt><dd>{{ activity.endTime ? activity.endTime|date('H:i') : '-' }}</dd>
                        <dt>Location</dt><dd>{{ activity.locationName ?: '-' }}</dd>
                        <dt>Cost</dt>
                        <dd>
                            {{ activity.currency }} {{ (activity.costAmount ?? 0)|number_format(2, '.', ',') }}
                            {% if showConvertedValues %}
                                <br><span class="muted">{{ selectedCurrency }} {{ activityCostConverted|number_format(2, '.', ',') }}</span>
                            {% endif %}
                        </dd>
                        <dt>Participants</dt><dd>{{ activity.participants|length }}</dd>
                        <dt>Available seats</dt><dd>{{ activity.availableSeats }} / {{ activity.totalCapacity }}</dd>
                        <dt>Your status</dt><dd>{{ isJoined ? 'Joined' : 'Not joined' }}</dd>
                    </dl>
                </section>

                <section class="glass-card panel-head">
                    <div>
                        <p class="eyebrow">Location Map</p>
                        <h2>Activity Location</h2>
                        <p class="muted">Pinpointed map for this activity location.</p>
                    </div>
                    <div class="actions">
                        {% if externalMapUrl %}
                            <a class="btn btn-sm" href="{{ externalMapUrl }}" target="_blank" rel="noopener"><i class="fa-solid fa-map-location-dot btn-icon" aria-hidden="true"></i>View on map</a>
                        {% endif %}
                    </div>
                </section>

                {% if hasActivityMapCoordinates %}
                    <section class="trip-map-weather-grid">
                        <article class="glass-card" data-controller="trip-map" data-trip-map-center-lat-value="{{ mapCenterLat is not null ? mapCenterLat : '' }}" data-trip-map-center-lng-value="{{ mapCenterLng is not null ? mapCenterLng : '' }}" data-trip-map-activities-value="{{ activityMapItems|json_encode }}" data-trip-map-center-label-value="Activity location" data-trip-map-show-center-marker-value="false">
                            <div class="panel-head">
                                <div>
                                    <p class="eyebrow">Activity Map</p>
                                    <h3>{{ activity.locationName ?: 'Pinned location' }}</h3>
                                </div>
                            </div>
                            <div class="trip-map-root" data-trip-map-root></div>
                        </article>
                    </section>
                {% else %}
                    <section class="glass-card center">
                        <p class="muted">Map data is unavailable for this activity right now. Add/confirm location coordinates to enable map pinning.</p>
                    </section>
                {% endif %}

                {% if activity.trip %}
                    <section class="glass-card center">
                        <p class="muted">Need full trip context before deciding?</p>
                        <a class="btn btn-primary" href="{{ path('trip_show', {'id': activity.trip.id}) }}">Open Related Trip</a>
                    </section>
                {% endif %}
            </div>
        </div>
    {% endif %}
{% endblock %}
