<article class="surface-card h-100 p-3">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h3 class="h5 mb-0">{{ activity.title }}</h3>
        {% set state = (activity.status ?? 'PLANNED') %}
        <span class="badge {% if state in ['COMPLETED','DONE'] %}text-bg-success{% elseif state == 'CANCELLED' %}text-bg-danger{% else %}text-bg-primary{% endif %}">
            {{ state }}
        </span>
    </div>
    <p class="small text-muted mb-1"><i class="bi bi-signpost-split me-1"></i>{{ activity.trip ? activity.trip.tripName : 'No trip' }}</p>
    <p class="small text-muted mb-1"><i class="bi bi-calendar3 me-1"></i>{{ activity.activityDate ? activity.activityDate|date('Y-m-d') : '-' }} | {{ activity.startTime ? activity.startTime|date('H:i') : '--:--' }} -> {{ activity.endTime ? activity.endTime|date('H:i') : '--:--' }}</p>
    <p class="small text-muted mb-2"><i class="bi bi-cash-stack me-1"></i>{{ activity.currency ?? 'USD' }} {{ activity.costAmount ?? 0 }}</p>
    <p class="small mb-3">{{ activity.description ? activity.description|slice(0, 100) ~ (activity.description|length > 100 ? '...' : '') : 'No description.' }}</p>
    <div class="d-flex gap-2 mt-auto">
        <a class="btn btn-sm btn-outline-primary" href="{{ path('app_activity_show', {'id': activity.id}) }}"><i class="bi bi-eye"></i></a>
        <a class="btn btn-sm btn-outline-warning" href="{{ path('app_activity_edit', {'id': activity.id}) }}"><i class="bi bi-pencil"></i></a>
    </div>
</article>
