{% extends 'base.html.twig' %}

{% block title %}Admin Menu - New Activity{% endblock %}

{% block body %}
    <section class="glass-card panel-head">
        <div>
            <p class="eyebrow">Admin Menu</p>
            <h1>Create activity</h1>
            <p class="muted">Add a new activity and link it to a trip.</p>
        </div>
        <div class="actions">
            <a class="btn" href="{{ path('admin_activity_index') }}">Back to list</a>
        </div>
    </section>

    {{ include('admin/_operations.html.twig', {active: 'activities'}) }}

    <section class="glass-card">
        {{ include('activity/_form.html.twig') }}
    </section>
{% endblock %}
